# // 2026-01-30-10-36-00 EST
# // cad_rms_data_quality/.gitignore
# // Author: R. A. Carucci
# // Purpose: Git ignore rules for CAD/RMS data quality project

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# =============================================================================
# Virtual Environments
# =============================================================================
env/
venv/
ENV/
env.bak/
venv.bak/
.venv/
.conda/

# =============================================================================
# IDE and Editors
# =============================================================================
.vscode/
.idea/
.claude/*
!.claude/skills/
*.swp
*.swo
*.swn
*~
.project
.pydevproject
.spyderproject
.spyproject
*.sublime-workspace
*.sublime-project

# =============================================================================
# Testing
# =============================================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# =============================================================================
# Type Checking
# =============================================================================
.mypy_cache/
.dmypy.json
dmypy.json

# =============================================================================
# Data Outputs (Large Files)
# =============================================================================
consolidation/output/*.csv
consolidation/output/*.xlsx
consolidation/reports/*.html
consolidation/reports/*.xlsx
consolidation/reports/*.json
consolidation/logs/*.log

monthly_validation/reports/*/
monthly_validation/logs/*.log

# =============================================================================
# Logs
# =============================================================================
*.log
logs/

# =============================================================================
# OS Generated
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Jupyter Notebooks
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# Secrets and Credentials
# =============================================================================
.env
.env.local
.env.*.local
*.pem
*.key
secrets.yaml
credentials.json

# =============================================================================
# Temporary Files
# =============================================================================
*.tmp
*.temp
*.bak
*.backup
~$*

# =============================================================================
# Keep Directory Structure (override above ignores)
# =============================================================================
!consolidation/output/.gitkeep
!consolidation/reports/.gitkeep
!consolidation/logs/.gitkeep
!monthly_validation/reports/.gitkeep
!monthly_validation/logs/.gitkeep
!tests/fixtures/.gitkeep
